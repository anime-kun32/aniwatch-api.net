

# env to control allowed origins
ANIWATCH_API_CORS_ALLOWED_ORIGINS=https://aniteams-next.netlify.app,https://anime-kun32.github.io,https://ani-teams.vercel.app,https://work-nu-tawny.vercel.app,https://anito.anixtv.in,https://goog-three.vercel.app,https://sample-hell-yeah.wuaze.com,https://test-anito-vercel.wuaze.com,https://hianime.zya.me,http://aniteams.free.nf,https://aniteam.rf.gd,https://aniteams-v2-inprogress.vercel.app,https://work-nu-tawny.vercel.app,https://aniteams-old.vercel.app,https://aniteams.wuaze.com,https://stackblitz-starters-axhv9hjz.vercel.app,https://hianime-spotlight.vercel.app,https://otaku-calendar.vercel.app

# RATE LIMIT
# duration to track requests (in milliseconds) for rate limiting. here, 30*60*1000 = 1800000 = 30 minutes
ANIWATCH_API_WINDOW_MS=1800000 
# maximum number of requests in this timeperiod
ANIWATCH_API_MAX_REQS=300

# CAUTION: 
#   For personal deployments, if you wanna have rate limitting
#   in your application, then set the env below to your deployed 
#   instance's hostname, otherwise don't set or have it at all.
#   If you set the env below to an incorrect value, you may face other issues.
# ANIWATCH_API_HOSTNAME=https://aniwatch-api-net.vercel.app


